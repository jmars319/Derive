{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tenra Derive",
  "version": "0.1.0",
  "identifier": "co.tenra.derive",
  "build": {
    "beforeDevCommand": "pnpm --filter @derive/desktopapp run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @derive/desktopapp run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "tenra Derive",
        "width": 1280,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
